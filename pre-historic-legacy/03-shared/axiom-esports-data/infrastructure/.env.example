# =============================================================================
# Axiom Esports Database Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For free-tier deployment, see options below

# =============================================================================
# LOCAL DEVELOPMENT (Docker Compose)
# =============================================================================

# PostgreSQL Configuration
POSTGRES_DB=axiom_esports
POSTGRES_USER=axiom
POSTGRES_PASSWORD=your_secure_local_password
POSTGRES_PORT=5432

# PGAdmin Configuration (optional)
PGADMIN_EMAIL=admin@axiom.local
PGADMIN_PASSWORD=your_pgadmin_password
PGADMIN_PORT=5050

# Redis Configuration
REDIS_PORT=6379

# =============================================================================
# PRODUCTION: SUPABASE (Recommended Free Tier)
# =============================================================================
# 500MB storage, 2M row reads/month, built-in connection pooling
# 
# 1. Create project at https://supabase.com
# 2. Go to Settings > Database > Connection string
# 3. Copy the "Transaction pooler" (port 6543) for serverless functions
# 4. Copy the "Session pooler" (port 5432) for long-running connections
#
# Uncomment and fill for Supabase:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase SSL Mode
# Use "require" for pooler (6543), "verify-full" for direct (5432) with certificates
# DB_SSL_MODE=require

# =============================================================================
# PRODUCTION: NEON (Serverless Postgres)
# =============================================================================
# 500MB storage, scales to zero, branching for dev/prod
#
# 1. Create project at https://neon.tech
# 2. Get connection string from Dashboard > Connection Details
# 3. Use pooled connection for applications
#
# Uncomment and fill for Neon:
# DATABASE_URL=postgresql://[user]:[password]@[project-ref].us-east-1.aws.neon.tech/[dbname]?sslmode=require

# Neon SSL Mode (always required)
# DB_SSL_MODE=require

# =============================================================================
# CONNECTION POOL SETTINGS (Free Tier Optimized)
# =============================================================================
# These settings are tuned for free-tier limits

# Maximum connections in pool (keep low for free tier: 3-10)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30

# Connection retry settings (for cloud databases)
DB_CONNECT_RETRY_ATTEMPTS=5
DB_CONNECT_RETRY_DELAY=2.0

# Connection timeout in seconds
DB_CONNECT_TIMEOUT=10

# Query timeout in seconds (prevent runaway queries)
DB_QUERY_TIMEOUT=30

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable SQL query logging (disable in production)
DB_ECHO=false

# =============================================================================
# SECURITY
# =============================================================================

# Never commit the actual .env file!
# For production, use your hosting platform's secret management:
# - Vercel: Environment Variables in Project Settings
# - Railway: Variables tab
# - Fly.io: fly secrets set
# - Render: Environment tab
