{
  "name": "@njz-os/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "NJZ RAT-OS webapp — Vite + React 19 SPA",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "@tanstack/react-query": "^5.59.0",
    "zustand": "^5.0.0",
    "@njz-os/core": "workspace:*",
    "@njz-os/ui": "workspace:*",
    "@njz-os/focus-engine": "workspace:*",
    "@njz-os/audio-engine": "workspace:*",
    "@njz-os/polyworld": "workspace:*",
    "@njz-os/progression": "workspace:*",
    "@njz-os/analytics": "workspace:*",
    "@njz-os/learning-cards": "workspace:*",
    "@njz-os/writing": "workspace:*"
  },
  "devDependencies": {
    "@njz-os/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0"
  }
}
