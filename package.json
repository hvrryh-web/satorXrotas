{
  "name": "njz-rat-os",
  "version": "0.1.0",
  "private": true,
  "description": "NJZ RAT-OS — Neural Operating System monorepo (marketing site + webapp)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:site": "turbo run dev --filter=@njz-os/site",
    "dev:web": "turbo run dev --filter=@njz-os/web",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "doc-tier:check": "node tools/doc-tier-check/index.mjs",
    "adr:new": "node tools/adr-new/index.mjs",
    "module:new": "node tools/module-new/index.mjs",
    "contracts:refresh-agent-gateway": "node tools/contracts/refresh-agent-gateway.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "turbo": "^2.9.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
