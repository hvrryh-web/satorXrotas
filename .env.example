# Local-dev placeholders for NJZ RAT-OS.
# Copy to .env.local and fill in. Do not commit real secrets.

# Site (apps/site, Next.js)
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_URL=http://localhost:7100
NEXT_PUBLIC_VAULTBRAIN_WS_URL=ws://localhost:7100/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Webapp (apps/web, Vite)
VITE_APP_ENV=local
VITE_API_URL=http://localhost:7100
VITE_WS_URL=ws://localhost:7100/ws
VITE_AGENT_GATEWAY_URL=http://localhost:7200
VITE_IDENTITY_URL=http://localhost:7300
VITE_STRICT_GATES=false

# Server-only (services/rat-os-api, Phase 2+)
# NODE_ENV=development
# VAULTBRAIN_API_URL=http://localhost:7100
# VAULTBRAIN_SHARED_SECRET=replace-me
# AGENT_GATEWAY_API_KEY=replace-me
# IDENTITY_JWKS_URL=http://localhost:7300/.well-known/jwks.json
