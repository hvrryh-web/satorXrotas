# =============================================================================
# SATOR Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/sator_db
DATABASE_POOL_SIZE=10

# --- API Keys ---
# Key used by the game to post match data to the API (private, server-side only)
GAME_API_KEY=your-game-api-key-here

# Key used by the web platform to read public stats from the API
WEB_API_KEY=your-web-api-key-here

# --- API URLs ---
# Internal API base URL (used by game and server-side web)
API_BASE_URL=http://localhost:3001

# Public API URL (used by browser-side web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Node Environment ---
NODE_ENV=development

# --- Optional: Feature Flags ---
ENABLE_FIREWALL_STRICT_MODE=true
ENABLE_DEBUG_LOGGING=false

# --- Kimi Code CLI (https://moonshotai.github.io/kimi-cli/) ---
# API key for the Moonshot AI platform.
# Obtain yours at: https://platform.moonshot.cn/console/api-keys
# In Codespaces this is set via repository/org Codespace secrets — no .env needed.
KIMI_API_KEY=your-moonshot-api-key-here
# Override the default API base URL if using a private endpoint or proxy.
KIMI_BASE_URL=https://api.moonshot.cn/v1
# Override the model name (default: kimi-k2-5).
# Available models: kimi-k2-5, kimi-for-coding, moonshot-v1-32k, moonshot-v1-128k
KIMI_MODEL_NAME=kimi-k2-5

# --- Liquipedia cross-reference (optional) ---
LIQUIPEDIA_API_TOKEN=your-liquipedia-token-here
