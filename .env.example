# =============================================================================
# SATOR Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/sator_db
DATABASE_POOL_SIZE=10

# --- API Keys ---
# Key used by the game to post match data to the API (private, server-side only)
GAME_API_KEY=your-game-api-key-here

# Key used by the web platform to read public stats from the API
WEB_API_KEY=your-web-api-key-here

# --- API URLs ---
# Internal API base URL (used by game and server-side web)
API_BASE_URL=http://localhost:3001

# Public API URL (used by browser-side web)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# --- Node Environment ---
NODE_ENV=development

# --- Optional: Feature Flags ---
ENABLE_FIREWALL_STRICT_MODE=true
ENABLE_DEBUG_LOGGING=false
